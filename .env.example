NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

DATABASE_URL=postgresql://g2sentry_app:changeme@localhost:5432/g2sentry?schema=public

DB_HOST=localhost
DB_PORT=5432
DB_NAME=g2sentry
DB_USER=g2sentry_app
DB_PASSWORD=changeme

# Set to false to run locally without Redis (in-memory fallback)
REDIS_ENABLED=true
REDIS_URL=redis://127.0.0.1:6379

JWT_SECRET=change-me
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-too
JWT_REFRESH_EXPIRES_IN=7d

OTP_MAX_ATTEMPTS=5
DISPATCH_OFFER_TTL_MS=90000

S3_BUCKET=g2sentry-docs
S3_REGION=af-south-1
