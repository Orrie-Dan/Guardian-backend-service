NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

DATABASE_URL=postgresql://g2sentry_app:changeme@localhost:5432/g2sentry?schema=public

DB_HOST=localhost
DB_PORT=5432
DB_NAME=g2sentry
DB_USER=g2sentry_app
DB_PASSWORD=changeme

# Set to false to run locally without Redis (in-memory fallback)
REDIS_ENABLED=true
REDIS_URL=redis://127.0.0.1:6379

JWT_SECRET=change-me
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-too
JWT_REFRESH_EXPIRES_IN=7d

OTP_MAX_ATTEMPTS=5
DISPATCH_OFFER_TTL_MS=90000
# Max time to search for a guardian before job status becomes FAILED (ms)
DISPATCH_WINDOW_MS=600000
DISPATCH_POOL_SIZE=50
MAX_OFFERS_PER_JOB=20
DISPATCH_UNREACHABLE_GRACE_MS=120000
URGENT_PARALLEL_OFFERS=3

# Hours after guardian completes before invoice auto-issues if client does not confirm
BILLING_AUTO_CONFIRM_HOURS=24

# Billing ops: early completion / late arrival thresholds (minutes)
BILLING_OPS_EARLY_COMPLETION_MINUTES=30
BILLING_OPS_LATE_ARRIVAL_MINUTES=15
# How far back the scheduled scan checks for anomalies (hours)
BILLING_OPS_SCAN_LOOKBACK_HOURS=24

# Pindo SMS (https://pindo.io) — OTP delivery in production
# Token: https://app.pindo.io/account (Security / API tokens)
PINDO_ENABLED=false
PINDO_API_TOKEN=
PINDO_SENDER=
# PINDO_API_URL=https://api.pindo.io/v1/sms/

S3_BUCKET=g2sentry-docs
S3_REGION=af-south-1

DOCUMENT_MAX_BYTES=10485760
